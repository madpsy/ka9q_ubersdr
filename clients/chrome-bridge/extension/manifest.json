{
  "manifest_version": 3,
  "name": "UberSDR Bridge",
  "version": "1.0.4",
  "description": "Bridges UberSDR to a local application via HTTP. Read and control frequency, mode, and bandwidth from any external program.",
  "author": "UberSDR",

  "permissions": [
    "activeTab",
    "tabs",
    "storage",
    "alarms"
  ],

  "host_permissions": [
    "http://localhost/*",
    "http://127.0.0.1/*",
    "http://ubersdr.local/*",
    "https://instances.ubersdr.org/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["page_world.js"],
      "run_at": "document_idle",
      "all_frames": false,
      "world": "MAIN"
    },
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle",
      "all_frames": false,
      "world": "ISOLATED"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "UberSDR Bridge",
    "default_icon": {
      "48": "icons/icon48.png",
      "96": "icons/icon96.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "48": "icons/icon48.png",
    "96": "icons/icon96.png",
    "128": "icons/icon128.png"
  }
}

# Galactic Unicorn Display Firmware — Configuration
# Copy this file to the Pico W as config.py and edit before first boot.

# ---------------------------------------------------------------------------
# Wi-Fi credentials
# ---------------------------------------------------------------------------
WIFI_SSID = "YourNetworkName"
WIFI_PASSWORD = "YourNetworkPassword"

# ---------------------------------------------------------------------------
# HTTP server
# ---------------------------------------------------------------------------
HTTP_PORT = 80          # Port the display server listens on
HTTP_HOST = "0.0.0.0"  # Listen on all interfaces

# ---------------------------------------------------------------------------
# Display defaults
# ---------------------------------------------------------------------------
DEFAULT_BRIGHTNESS = 0.5    # 0.0 (off) – 1.0 (full brightness)
QUEUE_MAX_SIZE = 16         # Maximum number of queued display messages

# ---------------------------------------------------------------------------
# Startup splash screen (shown while connecting to Wi-Fi)
# Set SPLASH_TEXT = "" to disable
# ---------------------------------------------------------------------------
SPLASH_TEXT = "UberSDR"
SPLASH_COLOR = "rainbow"    # Any valid colour from the protocol spec
SPLASH_SIZE = 3

# ---------------------------------------------------------------------------
# Idle display (shown when queue is empty and no forever-duration message)
# Set IDLE_TEXT = "" to disable idle display entirely (blank screen)
# ---------------------------------------------------------------------------
IDLE_TEXT = ""
IDLE_COLOR = "amber"
IDLE_SIZE = 1
IDLE_EFFECT = "static"
IDLE_ALIGN = "center"

# ---------------------------------------------------------------------------
# Hardware button behaviour
#
# Buttons (A/B/C/D):
#   A — Show IP address
#   B — Show Wi-Fi SSID + connection status
#   C — Clear display queue (restores idle display if configured)
#   D — Step brightness up by BRIGHTNESS_STEP; wraps from max back to min.
#       Hold D down to keep stepping (auto-repeat after BTN_D_HOLD_DELAY_MS,
#       then every BTN_D_REPEAT_MS).
#
# LUX +/- rocker (SWITCH_BRIGHTNESS_UP / SWITCH_BRIGHTNESS_DOWN):
#   Adjusts global brightness by BRIGHTNESS_STEP each press (no wrap, no hold-repeat).
# ---------------------------------------------------------------------------

# Brightness step size and limits (shared by LUX rocker and button D)
BRIGHTNESS_STEP = 0.1       # How much each press changes brightness (10%)
BRIGHTNESS_MIN = 0.05       # Minimum brightness (never fully off)
BRIGHTNESS_MAX = 1.0        # Maximum brightness

# Button A — show IP address
BTN_IP_PRIORITY = 8         # Priority of the IP display message (interrupts most content)
BTN_IP_DURATION = 5.0       # Seconds to show the IP before reverting
BTN_IP_COLOR = "cyan"       # Colour when connected; red is used automatically if disconnected

# Button B — show Wi-Fi status
BTN_WIFI_PRIORITY = 8       # Priority of the Wi-Fi status message
BTN_WIFI_DURATION = 5.0     # Seconds to show the status before reverting

# Button C — clear display (no extra config needed; always clears and reinstalls idle)

# Button D — step brightness
BTN_BRIGHTNESS_PRIORITY = 8    # Priority of the brief brightness-confirmation message
BTN_BRIGHTNESS_DURATION = 1.0  # Seconds to show the brightness percentage label
BTN_D_HOLD_DELAY_MS = 500      # ms held before auto-repeat begins
BTN_D_REPEAT_MS = 300          # ms between each auto-repeat step while held

# ---------------------------------------------------------------------------
# Network timeouts
# ---------------------------------------------------------------------------
WIFI_CONNECT_TIMEOUT = 20   # Seconds to wait for Wi-Fi connection
HTTP_READ_TIMEOUT = 5       # Seconds to wait for full HTTP request body

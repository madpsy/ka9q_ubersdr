  #   channels: [telegram_main]

  # - name: "System recovered"
  #   event: system_monitor
  #   filter:
  #     on_recovery: true
  #   template: "✅ <b>{{.Component}} recovered</b>"
  #   channels: [telegram_main]

  # ── System monitor: specific components ──────────────────────────────────────
  # - name: "CW Skimmer unhealthy"

# UberSDR Notification Configuration
# Copy this file to notifications.yaml and edit to suit your setup.
#
# The notification system is a self-contained hub:
#   - Sources (CW Skimmer, DX Cluster, decoder, etc.) publish typed events.
#   - The manager evaluates every rule against each event.
#   - All matching rules fire independently (multiple rules can match one event).
#   - Each rule renders its own template and dispatches to its own channel list.
#
# Supported event types:
#   cw_spot        — CW Skimmer spot received
#   dx_spot        — DX Cluster spot received
#   digital_decode — FT8 / FT4 / WSPR / JS8 decoded
#   space_weather  — K-index / A-index / SFI threshold crossed
#   antenna_switch — Antenna switch changed state
#   rotator        — Rotator moved or stopped
#   system_monitor — A subsystem became unhealthy or recovered
#   user_session   — A user connected or disconnected
#   server_startup — Server finished initialising (useful for crash detection)
#   voice_activity — New voice signal detected on a band

# ── Master switch ─────────────────────────────────────────────────────────────
# Set to true after configuring your channels and rules below.
enabled: false

# ── Channels ──────────────────────────────────────────────────────────────────
# Define one or more named output destinations.
# Rules reference channels by name.
channels:

  # ── Telegram ─────────────────────────────────────────────────────────────────
  # To set up a Telegram bot:
  #   1. Message @BotFather on Telegram → /newbot → copy the token.
  #   2. Add the bot to a group, or message it directly.
  #   3. GET https://api.telegram.org/bot<TOKEN>/getUpdates
  #      and find "chat":{"id":...} in the response.
  #
  # telegram_main:
  #   type: telegram
  #   bot_token: "7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  #   chat_id: "-1001234567890"   # group/channel (negative) or personal chat (positive)
  #   parse_mode: "HTML"          # HTML (default), Markdown, MarkdownV2, or "" for plain text
  #   rate_limit_minutes: 10      # suppress duplicate (rule+subject) alerts within this window
  #                               # 0 = no rate limiting

  # You can define multiple channels — e.g. a personal chat and a group:
  # telegram_personal:
  #   type: telegram
  #   bot_token: "7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
  #   chat_id: "123456789"        # your personal chat ID
  #   rate_limit_minutes: 0       # no rate limiting for personal alerts

# ── Rules ─────────────────────────────────────────────────────────────────────
# Rules are evaluated in order. All matching rules fire (no break-on-first-match).
# Omitting a filter field means "match anything" for that field.
# Within a list field, any element matching is sufficient (OR within field, AND between fields).
rules:

  # ── Server startup ────────────────────────────────────────────────────────────
  # Fires once when the server finishes initialising. Useful for detecting restarts.
  # - name: "Server started"
  #   event: server_startup
  #   template: "🚀 <b>UberSDR {{.Version}} started</b>\n{{.Callsign}} — {{.Name}}"
  #   channels: [telegram_main]

  # ── System monitor: any subsystem goes unhealthy ──────────────────────────────
  # Available components: noise_floor, space_weather, decoder, cw_skimmer, mqtt,
  #   rotator, ant_switch, frequency_reference, instance_reporter, sdr_frontend,
  #   gpsdo, system_load, cpu_temperature
  # Fires only on state transitions (healthy→unhealthy or unhealthy→healthy).
  # - name: "System unhealthy"
  #   event: system_monitor
  #   filter:
  #     on_unhealthy: true
  #     # components: ["decoder", "cw_skimmer", "mqtt"]  # empty = all components

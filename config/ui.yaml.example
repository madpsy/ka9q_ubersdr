# UberSDR Web UI Defaults
# These settings control the default appearance for all new visitors.
# Individual users can override any of these via the UI controls,
# and their personal preference is saved in browser localStorage.
# The server default only applies when a user has no saved preference for that setting.
#
# To add a new palette (after implementing it in spectrum-display.js):
#   Simply add a new entry to the palette.available list below.
#   It will automatically appear as an option in the admin UI.
#   No Go code or HTML changes are required.

ui:
  # Default signal bar meter mode for new visitors
  # The signal bar meter sits under the waterfall and shows signal strength
  # Users can click the meter to cycle through modes
  # localStorage key: signalMeterDisplayMode
  signal_meter_mode:
    default: "dbfs"
    available:
      - value: "dbfs"
        label: "dBFS Bar"
      - value: "snr"
        label: "SNR Bar"
      - value: "dbfs-led"
        label: "dBFS LED"
      - value: "snr-led"
        label: "SNR LED"

  # Default S-meter display mode for new visitors
  # Controls which mode the needle S-meter (canvas) starts in
  # Users can click the S-meter canvas to cycle through modes
  # localStorage key: ubersdr_smeter_colour_mode
  smeter_mode:
    default: "smeter-classic"
    available:
      - value: "smeter-classic"
        label: "S-Meter (Classic)"
      - value: "snr-classic"
        label: "SNR Meter (Classic)"
      - value: "smeter-dynamic"
        label: "S-Meter (Dynamic colour)"
      - value: "snr-dynamic"
        label: "SNR Meter (Dynamic colour)"

  # Default waterfall colour palette for new visitors
  # localStorage key: spectrumColorScheme
  # To add a new palette: add an entry to 'available' below (after adding it to spectrum-display.js)
  palette:
    default: "jet"
    available:
      - value: "jet"
        label: "Jet"
      - value: "turbo"
        label: "Turbo"
      - value: "viridis"
        label: "Viridis"
      - value: "plasma"
        label: "Plasma"

  # Default auto-contrast value for new visitors
  # Symmetric dB offset applied to the auto-range window:
  #   floor is raised by +N dB, ceiling is lowered by -N dB
  # Range: 0-20 (matches the Contrast slider in the spectrum controls)
  # localStorage key: spectrumAutoContrast
  contrast:
    default: 10
    min: 0
    max: 20

  # Default VU meter display style for new visitors
  # localStorage key: vuMeterStyle
  vu_meter_style:
    default: "bar"
    available:
      - value: "bar"
        label: "Bar"
      - value: "led"
        label: "LED"

  # Default GPU sub-pixel waterfall scroll for new visitors
  # Smoother 60fps scrolling using CSS transform compositing
  # Disable if users report visual glitches on older hardware
  # localStorage key: spectrumGpuScrollEnabled
  gpu_scroll:
    default: false

  # Default spatial smoothing for new visitors
  # Reduces noise fuzziness in the spectrum display
  # localStorage key: spectrumSmoothEnabled
  smoothing:
    default: false

  # Default peak hold for new visitors
  # Shows the highest signal level reached in the spectrum display
  # localStorage key: spectrumHoldEnabled
  peak_hold:
    default: true

  # Default spectrum split view for new visitors
  # Shows a spectrum line graph above the waterfall in a split-screen layout
  # Corresponds to the 'Spectrum' checkbox in the UI controls
  # localStorage key: spectrumLineGraphEnabled
  line_graph:
    default: false

  # Default bandwidth indicator colour for new visitors
  # The coloured bar drawn on the waterfall/overlay canvas showing the tuned receive bandwidth.
  # Users can right-click the bandwidth indicator bar to change the colour; their choice is
  # saved in browser localStorage and always takes priority over this server default.
  # localStorage key: bandwidthIndicatorColor
  bandwidth_indicator_color:
    default: "green"
    available:
      - value: "green"
        label: "Green (default)"
      - value: "red"
        label: "Red"
      - value: "cyan"
        label: "Cyan"
      - value: "white"
        label: "White"
      - value: "yellow"
        label: "Yellow"
      - value: "orange"
        label: "Orange"
      - value: "magenta"
        label: "Magenta"

  # Band colour intensity for the amateur band overlays in the bookmark area.
  # Controls how vivid the coloured band backgrounds appear on the spectrum.
  # At 0.5 (default) the appearance matches the original hardcoded pastel palette exactly.
  # 0.0 = softest (alpha 0.10, high colour floor — still visible), 0.5 = default pastel,
  # 1.0 = most vivid (alpha 0.30, low colour floor — bold saturated colours).
  # No localStorage key — this is an operator setting; users cannot override it individually.
  band_color_intensity: 0.5

  # Station ID overlay on the spectrum line graph
  # When enabled, shows "<callsign> - <name>" on the first line and "<location>" on the
  # second line, right-aligned in the top-right corner of the spectrum drawing area.
  # Values come from the admin > Station Info section (callsign, name, location fields).
  # This is a server-side operator setting — users cannot override it individually.
  # No localStorage key.
  station_id_overlay: true

  # Hex colour for the station ID overlay text (#rrggbb).
  # The location line is drawn at 75% opacity of this colour.
  # A 1 px black drop-shadow is always added for legibility over any background.
  station_id_color: "#ffffff"

  # Theme colour overrides — all values are 6-digit hex colours (#rrggbb).
  # When absent the built-in defaults reproduce the original appearance exactly.
  # theme:
  #   page_bg:      "#adb5bd"  # Background of panels below the waterfall
  #   panel_dark:   "#2c3e50"  # Dark widget backgrounds (S-meter, canvases, modals)
  #   panel_mid:    "#34495e"  # Section headers, control group backgrounds
  #   accent:       "#667eea"  # Hover states, primary buttons, gradient start
  #   accent_end:   "#764ba2"  # End colour of accent gradients
  #   text_light:   "#ecf0f1"  # Text on dark panel backgrounds
  #   control_text: "#495057"  # Labels on light backgrounds (Volume, Left, Right, Low, High, Scroll…)
